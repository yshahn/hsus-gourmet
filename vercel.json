{
  "version": 2,
  "functions": {
    "api/checkout.js": {
      "maxDuration": 10
    },
    "api/notify-order.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
